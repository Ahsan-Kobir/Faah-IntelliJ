<idea-plugin>
    <id>com.github.faah</id>
    <name>Faah</name>
    <vendor url="https://github.com/Ahsan-Kobir/Faah-IntelliJ" email="">Ahsan-Kobir</vendor>
    <description><![CDATA[
        <b>Faah</b> — Exception Sound Alerter<br><br>
        Plays a custom sound alert whenever an exception, error, or fatal crash is detected
        in any console, terminal, run configuration, or Android Logcat output.<br><br>
        <b>Features:</b>
        <ul>
            <li>On/off toggle button in the toolbar</li>
            <li>Monitors all console and terminal output for exceptions</li>
            <li>Plays a sound alert on detection (with 2-second debounce to avoid spam)</li>
            <li>Works with run configurations, tests, Gradle output, and Android Logcat</li>
        </ul>
        <b>Source:</b> <a href="https://github.com/Ahsan-Kobir/Faah-IntelliJ">GitHub</a>
    ]]></description>
    <change-notes><![CDATA[
        <b>1.0.0</b> — Initial release.
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Singleton service holding the enabled flag and exception pattern -->
        <applicationService
            serviceImplementation="com.github.faah.ExceptionDetectorService"/>

        <!-- Hooks into every ConsoleView (run configs, tests, Gradle, Logcat) -->
        <consoleFilterProvider
            implementation="com.github.faah.ExceptionConsoleFilterProvider"/>

    </extensions>

    <actions>
        <action id="Faah.ToggleMonitor"
                class="com.github.faah.ToggleMonitorAction"
                text="Monitor Exceptions"
                description="Toggle exception sound alerts on or off">
            <!-- New UI toolbar (IntelliJ 2022.3+) -->
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <!-- Classic UI navbar toolbar -->
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
            <!-- Also available under Tools menu -->
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

    <!-- Attaches a ProcessListener to every run/debug process for output capture -->
    <projectListeners>
        <listener class="com.github.faah.TerminalOutputListener"
                  topic="com.intellij.execution.ExecutionListener"/>
    </projectListeners>

</idea-plugin>
